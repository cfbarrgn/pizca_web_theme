<section id="shop" class="products">
  <div class="products-head">
    <div>
      <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="section-title">{{ section.settings.title | replace: '*', '<em>' | replace: '*', '</em>' }}</h2>
    </div>
    {%- if section.settings.collection != blank -%}
      <a href="{{ collections[section.settings.collection].url }}" class="view-all">View All &rarr;</a>
    {%- endif -%}
  </div>

  <div class="products-grid">
    {%- assign featured_collection = collections[section.settings.collection] -%}
    {%- assign product_limit = section.settings.products_to_show -%}

    {%- if featured_collection != blank -%}
      {%- for product in featured_collection.products limit: product_limit -%}
        {% render 'product-card', product: product %}
      {%- endfor -%}
    {%- else -%}
      {%- comment -%}Fallback: show featured products set in blocks{%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'product' and block.settings.product != blank -%}
          {% render 'product-card', product: block.settings.product %}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "The Collection"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title (wrap word in * for italic+color)",
      "default": "Our *Sauces*"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to display"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Number of products",
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product (manual fallback)",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Featured Products" }
  ]
}
{% endschema %}
