<div class="marquee-wrap">
  <div class="marquee-track">
    {%- assign items = section.settings.marquee_text | split: '|' -%}
    {%- comment -%}Duplicate for seamless loop{%- endcomment -%}
    {%- for run in (1..2) -%}
      {%- for item in items -%}
        <span>{{ item | strip }}</span><span class="sep">✦</span>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Marquee",
  "settings": [
    {
      "type": "textarea",
      "id": "marquee_text",
      "label": "Marquee items (separate with |)",
      "default": "Hand-Toasted Chiles | Small Batch | Single-Origin Olive Oil | No Preservatives | Oaxaca, Mexico"
    }
  ],
  "presets": [
    { "name": "Marquee Ticker" }
  ]
}
{% endschema %}
