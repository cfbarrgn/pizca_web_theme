<section id="stores" class="stores">
  <div class="stores-head">
    <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="section-title">{{ section.settings.title }}</h2>
  </div>

  <div class="stores-grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'store' -%}
        <div class="store-card reveal" {{ block.shopify_attributes }}>
          <div class="store-city">{{ block.settings.city }}</div>
          <div class="store-country">{{ block.settings.country }}{% if block.settings.label != blank %} &middot; {{ block.settings.label }}{% endif %}</div>
          <div class="store-address">{{ block.settings.address }}</div>
          {%- if block.settings.hours != blank -%}
            <div class="store-hours">{{ block.settings.hours }}</div>
          {%- endif -%}
          {%- if block.settings.map_url != blank -%}
            <a href="{{ block.settings.map_url }}" class="store-link" target="_blank" rel="noopener">Get Directions</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="stores-cta">
    <p>{{ section.settings.cta_text }}</p>
    <a href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}" class="btn-primary">
      {{ section.settings.cta_label }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Stores",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Find Us"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "In Stores Near You"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA supporting text",
      "default": "Can't find us near you? We ship worldwide."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Order Online"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button URL"
    }
  ],
  "blocks": [
    {
      "type": "store",
      "name": "Store location",
      "settings": [
        {
          "type": "text",
          "id": "city",
          "label": "City",
          "default": "Oaxaca"
        },
        {
          "type": "text",
          "id": "country",
          "label": "Country",
          "default": "Mexico"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label (e.g. Flagship)",
          "default": "Flagship"
        },
        {
          "type": "textarea",
          "id": "address",
          "label": "Address",
          "default": "Calle Reforma 402, Centro Histórico"
        },
        {
          "type": "text",
          "id": "hours",
          "label": "Opening hours",
          "default": "Mon–Sat 9am–7pm · Sun 10am–4pm"
        },
        {
          "type": "url",
          "id": "map_url",
          "label": "Google Maps URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stores",
      "blocks": [
        { "type": "store", "settings": { "city": "Oaxaca", "country": "Mexico", "label": "Flagship" } },
        { "type": "store", "settings": { "city": "New York", "country": "United States" } },
        { "type": "store", "settings": { "city": "London", "country": "United Kingdom" } }
      ]
    }
  ]
}
{% endschema %}
