<footer>
  <div class="footer-top">

    <div class="footer-brand">
      <a href="{{ routes.root_url }}" class="logo">Pi<span>z</span>ca</a>
      <p class="footer-tagline">{{ section.settings.tagline }}</p>
      <p>{{ section.settings.description }}</p>
    </div>

    {%- for block in section.blocks -%}
      {%- if block.type == 'menu_column' -%}
        <div class="footer-col" {{ block.shopify_attributes }}>
          <h4>{{ block.settings.heading }}</h4>
          <ul>
            {%- for link in linklists[block.settings.menu].links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endfor -%}

  </div>

  <div class="footer-bottom">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      &nbsp;&middot;&nbsp;
      <a href="{{ pages['privacy-policy'].url | default: '#' }}">Privacy</a>
      &nbsp;&middot;&nbsp;
      <a href="{{ pages['terms-of-service'].url | default: '#' }}">Terms</a>
    </p>
    <div class="payment-icons">
      {%- for type in shop.enabled_payment_types -%}
        {{ type | payment_type_svg_tag: class: 'payment-icon' }}
      {%- endfor -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Chile in oil. Made the traditional way."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Brand description",
      "default": "Small batch, hand-crafted chile in oil made in Michigan, USA. No preservatives. No shortcuts. Just flavorful fire."
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu_column", "settings": { "heading": "Shop" } },
        { "type": "menu_column", "settings": { "heading": "Explore" } },
        { "type": "menu_column", "settings": { "heading": "Help" } }
      ]
    }
  ]
}
{% endschema %}
