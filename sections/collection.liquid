<section class="products collection-page">
  <div class="products-head">
    <div>
      <p class="section-eyebrow">Shop</p>
      <h2 class="section-title">{{ collection.title }}</h2>
    </div>
    <span class="collection-count">{{ collection.products_count }} products</span>
  </div>

  {%- if collection.description != blank -%}
    <div class="collection-desc">{{ collection.description }}</div>
  {%- endif -%}

  <div class="products-grid">
    {%- for product in collection.products -%}
      {% render 'product-card', product: product %}
    {%- else -%}
      <p class="empty-collection">No products found in this collection.</p>
    {%- endfor -%}
  </div>

  {%- if paginate.pages > 1 -%}
    <div class="pagination">
      {{ paginate | default_pagination }}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Collection",
  "settings": [],
  "presets": [
    { "name": "Collection Page" }
  ]
}
{% endschema %}
